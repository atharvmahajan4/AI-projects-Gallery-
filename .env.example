# Copy this file to ".env" and fill in your real key.
# Get a free key from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-key-here

# Optional: change which Gemini model the backend calls.
# gemini-2.5-flash is fast and on the free tier; gemini-2.5-pro is more
# thorough but slower/costlier if you have paid access.
GEMINI_MODEL=gemini-2.5-flash
